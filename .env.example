# Anthropic API
ANTHROPIC_AUTH_TOKEN=sk-ant-...
# Optional: set for corporate gateways / proxies
# ANTHROPIC_BASE_URL=https://models.example.com/claude

# X API
X_API_BEARER_TOKEN=...
X_API_CLIENT_ID=...
X_API_CLIENT_SECRET=...
X_API_USER_ID=...

